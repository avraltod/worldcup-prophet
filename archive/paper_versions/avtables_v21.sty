% =====================================================================
%  avtables.sty  —  Avralt-Od Purevjav house style for tables & figures
%  Single source of truth. Deploy by copying this file into a project
%  (local dir or Overleaf upload), then in the preamble:  \usepackage{avtables}
%
%  Scope: TABLE and FIGURE formatting only. It deliberately does NOT set
%  margins, fonts, spacing, or bibliography — those are document-level
%  choices, so this package is safe to load under any document class
%  (article, AEA, elsarticle, the Science template, etc.).
%
%  Derived from the MGL/jamy (Mongolia grassland) format:
%    - regression tables: esttab `fragment` rows \input into a
%      threeparttable + full-width tabular* with dcolumn decimal alignment
%    - figures: \includegraphics wrapped in threeparttable so the note
%      renders as a tablenotes block beneath the image
%
%  v1.0  2026-06-08
% =====================================================================
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{avtables}[2026/06/08 v1.0 Avraa house style: tables & figures]

% --- core table machinery -------------------------------------------
\RequirePackage{booktabs}                  % \toprule \midrule \bottomrule
\RequirePackage{array}                     % column tweaks
\RequirePackage{dcolumn}                   % D{.}{.}{n} decimal alignment
\RequirePackage{multirow}
\RequirePackage[flushleft]{threeparttable} % table/figure + tablenotes
\RequirePackage{caption}                   % caption control
\RequirePackage{subcaption}                % \begin{subfigure} panels

% --- significance stars from esttab ---------------------------------
% esttab emits \sym{***} in its output; the preamble must define \sym.
% The jamy house choice is to RIGHT-OVERLAP the stars (\rlap) so they take
% zero width and the decimal points stay aligned across columns. (The more
% common alternative is superscript stars: \ifmmode^{#1}\else\(^{#1}\)\fi.)
\providecommand{\sym}[1]{\rlap{#1}}

% --- reusable bits so notes stay consistent -------------------------
% Standard significance footnote line — drop into any tablenotes block.
\newcommand{\signote}{Significance: *** $p<0.01$, ** $p<0.05$, and * $p<0.10$.}

% Decimal-aligned columns: use dcolumn's literal form in the preamble,
%   e.g.  l *{6}{D{.}{.}{4}}   (6 columns, 4 decimals).
% (A \dcol macro is intentionally NOT provided — a macro cannot expand
%  inside a tabular column spec without extra machinery, so the literal
%  form is both required and clearer.)

% Standard tablenotes opener used across the house style:
%   \begin{tablenotes}\notesize \item Note: ... \signote \end{tablenotes}
\newcommand{\notesize}{\footnotesize}

% --- a small CNY/yuan glyph (carried over from jamy) ----------------
\providecommand{\yuan}{{\setbox0=\hbox{Y}Y\kern-.97\wd0\vbox{\hrule height.1ex
  width.98\wd0\kern.33ex\hrule height.1ex width.98\wd0\kern.45ex}}}

\endinput
